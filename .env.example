# Copy this file to .env (which is gitignored) and fill in your values.
# Real environment variables (export FOO=bar in your shell) always override .env.

# Databricks SQL warehouse (lua/databricks.lua)
DATABRICKS_PROFILE=
DATABRICKS_WAREHOUSE_ID=
DATABRICKS_CATALOG=

# CDP Impala CLI (lua/cdp.lua) — local checkout path + default database
CDP_REPO=
CDP_DATABASE=dwh

# Optional: override the substring used to detect CDP SQL buffers.
# Defaults to the basename of CDP_REPO.
# CDP_MARKER=

# Optional: provider API keys
# GLM_API_KEY=
# MINIMAX_API_KEY=
